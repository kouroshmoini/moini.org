---
layout: null
permalink: /assets/search.json
---

{% assign now_unix = site.time | date: "%s" | plus: 0 %}

[
  {% assign comma = false %}

  {% for post in site.posts %}
    {% assign show_post = true %}
    {% if post.publish_mode == "schedule" %}
      {% assign show_post = false %}
      {% if post.publish_at %}
        {% assign post_publish_unix = post.publish_at | date: "%s" | plus: 0 %}
        {% if post_publish_unix <= now_unix %}
          {% assign show_post = true %}
        {% endif %}
      {% endif %}
    {% elsif post.publish_mode == "now" %}
      {% assign show_post = true %}
    {% else %}
      {% if post.published == false %}
        {% assign show_post = false %}
      {% endif %}
      {% if post.publish_at and post.published == false %}
        {% assign post_publish_unix = post.publish_at | date: "%s" | plus: 0 %}
        {% if post_publish_unix <= now_unix %}
          {% assign show_post = true %}
        {% endif %}
      {% endif %}
    {% endif %}
    {% if show_post %}
      {% assign display_date = post.publish_at | default: post.date %}
      {% if comma %},{% endif %}
      {
        "type": "Post",
        "title": {{ post.title | jsonify }},
        "url": {{ post.url | relative_url | jsonify }},
        "date": {{ display_date | date: "%b %d, %Y" | jsonify }},
        "text": {{ post.content | strip_html | strip_newlines | jsonify }}
      }
      {% assign comma = true %}
    {% endif %}
  {% endfor %}

  {% for p in site.pages %}
    {% assign show_page = true %}
    {% if p.published == false %}
      {% assign show_page = false %}
    {% endif %}
    {% if p.title and p.url and show_page %}
      {% assign is_search = p.url contains "/assets/search.json" %}
      {% assign is_feed = p.url contains "/feed" %}
      {% assign is_sitemap = p.url contains "sitemap" %}
      {% assign is_404 = p.url contains "404" %}

      {% assign is_resume_url = p.url == "/resume/" or p.url contains "/resume/" %}
      {% assign is_resume_title = p.title == "Resume" %}

      {% unless is_search or is_feed or is_sitemap or is_404 or is_resume_url or is_resume_title %}
        {% if comma %},{% endif %}
        {
          "type": "Page",
          "title": {{ p.title | jsonify }},
          "url": {{ p.url | relative_url | jsonify }},
          "date": "",
          "text": {{ p.content | strip_html | strip_newlines | jsonify }}
        }
        {% assign comma = true %}
      {% endunless %}
    {% endif %}
  {% endfor %}
]
